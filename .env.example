# BlueBird Agent — Environment Configuration
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local — only this example template.

# ───── App ─────
NEXT_PUBLIC_APP_NAME="BlueBird Agent"
NEXT_PUBLIC_APP_URL="https://bluebird-agent.vercel.app"

# ───── AI Provider (MiMo / OpenAI-compatible) ─────
# MiMo API: https://platform.xiaomimimo.com
MIMO_API_KEY=""
MIMO_API_BASE="https://api.xiaomimimo.com/v1"
MIMO_MODEL="mimo-vl-7b"

# Fallback: any OpenAI-compatible endpoint (9router, OpenRouter, etc.)
OPENAI_API_KEY=""
OPENAI_API_BASE="http://localhost:20128/v1"
OPENAI_MODEL="opus-primary"

# ───── Backend Agent (read-only public demo) ─────
# Path to BlueBird airdrops.db on the host running the agent runtime.
# In production this is proxied via a read-only API; web app never touches it directly.
BLUEBIRD_AGENT_API_URL="http://localhost:8787"
BLUEBIRD_AGENT_API_KEY=""

# ───── Demo Wallet (read-only addresses, NEVER private keys) ─────
NEXT_PUBLIC_DEMO_EVM_ADDRESS="0x0000000000000000000000000000000000000000"
NEXT_PUBLIC_DEMO_SOL_ADDRESS=""

# ───── Telegram Forum (public stats only) ─────
NEXT_PUBLIC_TG_FORUM_URL=""

# ───── Analytics (optional) ─────
NEXT_PUBLIC_VERCEL_ANALYTICS="false"
